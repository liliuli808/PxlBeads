# Development only: if wrangler dev runs on a different port than Vite,
# point the Jimeng client directly at it. In production this is not needed
# because the Worker entry handles /api/jimeng/redraw on the same origin.
VITE_JIMENG_API_URL=http://localhost:8787/api/jimeng/redraw

# Lightweight Jimeng website sessionid reverse proxy.
# JIMENG_SESSION_IDS is a Worker secret. Do not expose it as a Vite variable.
# Multiple sessionids can be separated by commas.
#   wrangler secret put JIMENG_SESSION_IDS

# Optional model override. Defaults to jimeng-image-5.0-lite.
# JIMENG_IMAGE_MODEL=jimeng-image-5.0-lite

# Optional upstream override. Defaults to https://jimeng.jianying.com.
# JIMENG_WEB_BASE_URL=https://jimeng.jianying.com

# Optional local/debug polling knobs.
# JIMENG_POLL_INTERVAL_MS=1000
# JIMENG_MAX_POLL_RETRIES=120

# Optional fallback: official Jimeng / Volcano Ark image-generation credentials.
# ARK_API_KEY is also a Worker secret. Do not expose it as a Vite variable.
#   wrangler secret put ARK_API_KEY

# ARK_IMAGE_MODEL is the Model ID or Endpoint ID from the Volcano Ark console.
# For local wrangler dev, put it in .dev.vars; for deploys, set it in wrangler.toml [vars]
# or in the Cloudflare dashboard variables.
# ARK_IMAGE_MODEL=your_seedream_model_or_endpoint_id

# Optional override. Defaults to https://ark.cn-beijing.volces.com/api/v3.
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
